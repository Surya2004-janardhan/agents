// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  // DATABASE_URL  = pooled Neon connection (used by app at runtime)
  // DIRECT_URL    = direct Neon connection (used by prisma migrate)
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String?
  avatar     String?
  bio        String?
  provider   String
  providerId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sessions     Session[]
  subscription Subscription?
  agents       Agent[]
  workflows    Workflow[]
  runs         Run[]
  auditLogs    AuditLog[]
  usageDaily   UsageDaily[]
  knowledgeBases KnowledgeBase[]
  executionLogs ExecutionLog[]
  tools        Tool[]
  toolUsages   ToolUsage[]
  webhooks     Webhook[]
  events       Event[]
  userCredentials UserCredential[]

  @@unique([provider, providerId])
  @@map("users")
}

model UserCredential {
  id           String   @id @default(uuid())
  userId       String
  provider     String   // e.g., "instagram", "youtube"
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("user_credentials")
}

model AgentTemplate {
  id          String   @id @default(uuid())
  name        String
  description String
  category    String
  prompt      String
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agents Agent[]

  @@map("agent_templates")
}

model Agent {
  id           String   @id @default(uuid())
  userId       String
  templateId   String?
  name         String
  description  String?
  systemPrompt String?
  provider     String
  model        String
  temperature  Float    @default(0.7)
  maxTokens    Int      @default(512)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  template AgentTemplate? @relation(fields: [templateId], references: [id])
  runs     Run[]
  workflowSteps WorkflowStep[]

  @@map("agents")
}

model Workflow {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  scheduleCron String?
  scheduleInput String?
  scheduleEnabled Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  steps WorkflowStep[]
  runs  Run[]

  @@map("workflows")
}

model WorkflowStep {
  id         String   @id @default(uuid())
  workflowId String
  order      Int
  agentId    String
  config     Json
  createdAt  DateTime @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  agent    Agent    @relation(fields: [agentId], references: [id])

  @@unique([workflowId, order])
  @@map("workflow_steps")
}

model Run {
  id          String   @id @default(uuid())
  userId      String
  type        String
  status      String
  jobId       String?
  agentId     String?
  workflowId  String?
  input       Json?
  output      Json?
  error       String?
  tokens      Int?
  cost        Float?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent    Agent?    @relation(fields: [agentId], references: [id])
  workflow Workflow? @relation(fields: [workflowId], references: [id])

  @@map("runs")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  targetType String?
  targetId   String?
  meta       Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model UsageDaily {
  id       String   @id @default(uuid())
  userId   String
  date     DateTime
  requests Int      @default(0)
  tokens   Int      @default(0)
  cost     Float    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("usage_daily")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Subscription {
  id               String   @id @default(uuid())
  userId           String   @unique
  externalCustomerId String?
  plan             String   @default("free")
  status           String   @default("active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ─── Knowledge Base / RAG ───────────────────────────────────────────────────
model KnowledgeBase {
  id        String   @id @default(uuid())
  userId    String
  name      String
  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents KnowledgeBaseDocument[]

  @@map("knowledge_bases")
}

model KnowledgeBaseDocument {
  id             String   @id @default(uuid())
  knowledgeBaseId String
  fileName       String
  fileUrl        String
  fileSize       Int
  fileType       String
  textContent    String   @db.Text
  embedding      String?  @db.Text
  metadata       Json?
  createdAt      DateTime @default(now())

  knowledgeBase KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  @@map("knowledge_base_documents")
}

// ─── Advanced Logging & Tracing ────────────────────────────────────────────
model ExecutionLog {
  id          String   @id @default(uuid())
  runId       String   @unique
  userId      String
  agentId     String?
  workflowId  String?
  status      String
  startedAt   DateTime
  completedAt DateTime?
  duration    Int?
  metadata    Json?
  createdAt   DateTime @default(now())

  steps ExecutionStep[]
  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("execution_logs")
}

model ExecutionStep {
  id             String   @id @default(uuid())
  executionLogId String
  stepNumber     Int
  name           String
  status         String
  input          Json?
  output         Json?
  error          String?
  duration       Int?
  tokens        Int?
  timestamps     Json?
  createdAt      DateTime @default(now())

  executionLog ExecutionLog @relation(fields: [executionLogId], references: [id], onDelete: Cascade)

  @@map("execution_steps")
}

// ─── Tool Integration ──────────────────────────────────────────────────────
model Tool {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  category    String
  enabled     Boolean  @default(true)
  config      Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tools")
}

model ToolUsage {
  id         String   @id @default(uuid())
  userId     String
  runId      String
  toolName   String
  input      Json?
  output     Json?
  error      String?
  duration   Int?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tool_usage")
}

// ─── Webhooks & Events ────────────────────────────────────────────────────
model Webhook {
  id      String   @id @default(uuid())
  userId  String
  url     String
  events  String[] @default([])
  active  Boolean  @default(true)
  secret  String
  retries Int      @default(3)
  timeout Int      @default(30000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@map("webhooks")
}

model Event {
  id         String   @id @default(uuid())
  userId     String
  type       String
  runId      String?
  workflowId String?
  agentId    String?
  payload    Json?
  metadata   Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("events")
}

model WebhookDelivery {
  id          String   @id @default(uuid())
  webhookId   String
  eventType   String
  payload     Json
  status      Int?
  response    String?
  attempts    Int      @default(0)
  nextRetry   DateTime?
  deliveredAt DateTime?
  createdAt   DateTime @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@map("webhook_deliveries")
}
